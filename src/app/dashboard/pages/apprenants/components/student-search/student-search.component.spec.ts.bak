import { ComponentFixture, TestBed } from '@angular/core/testing';
import { FormsModule } from '@angular/forms';
import { StudentSearchComponent } from './student-search.component';
import { StudentFilters } from '../../models/student.model';

describe('StudentSearchComponent', () => {
  let component: StudentSearchComponent;
  let fixture: ComponentFixture<StudentSearchComponent>;

  beforeEach(async () => {
    await TestBed.configureTestingModule({
      imports: [FormsModule, StudentSearchComponent],
    }).compileComponents();
  });

  beforeEach(() => {
    fixture = TestBed.createComponent(StudentSearchComponent);
    component = fixture.componentInstance;
    fixture.detectChanges();
  });

  it('should create', () => {
    expect(component).toBeTruthy();
  });

  it('should emit search value on change', () => {
    const searchValue = 'test';
    spyOn(component.search, 'emit');

    component.onSearchChange(searchValue);

    expect(component.search.emit).toHaveBeenCalledWith(searchValue);
  });

  it('should add search term to history', () => {
    const searchTerm = 'test';

    component.onSearchChange(searchTerm);

    expect(component.searchHistory).toContain(searchTerm);
  });

  it('should not add empty search term to history', () => {
    const initialHistoryLength = component.searchHistory.length;

    component.onSearchChange('  ');

    expect(component.searchHistory.length).toBe(initialHistoryLength);
  });

  it('should respect maxHistoryItems limit', () => {
    component.maxHistoryItems = 3;

    component.onSearchChange('term1');
    component.onSearchChange('term2');
    component.onSearchChange('term3');
    component.onSearchChange('term4');

    expect(component.searchHistory.length).toBe(3);
    expect(component.searchHistory).not.toContain('term1');
  });

  it('should toggle filters visibility', () => {
    const initialState = component.showFilters;

    component.toggleFilters();
    expect(component.showFilters).toBe(!initialState);

    component.toggleFilters();
    expect(component.showFilters).toBe(initialState);
  });

  it('should emit filter changes', () => {
    spyOn(component.filtersChange, 'emit');
    const filters: StudentFilters = {
      firstName: 'John',
      lastName: 'Doe',
      email: 'john@example.com',
      level: '',
      status: '',
      nationality: '',
    };

    component.filters = filters;
    component.onFiltersChange();

    expect(component.filtersChange.emit).toHaveBeenCalledWith(filters);
  });

  it('should clear filters', () => {
    component.filters = {
      firstName: 'John',
      lastName: 'Doe',
      email: 'john@example.com',
      level: 'B2',
      status: 'ACTIVE',
      nationality: 'FR',
    };
    spyOn(component.filtersChange, 'emit');

    component.clearFilters();

    expect(component.filters).toEqual({
      firstName: '',
      lastName: '',
      email: '',
      level: '',
      status: '',
      nationality: '',
    });
    expect(component.filtersChange.emit).toHaveBeenCalled();
  });

  it('should apply history term', () => {
    const term = 'test';
    spyOn(component.search, 'emit');

    component.applyHistoryTerm(term);

    expect(component.searchValue).toBe(term);
    expect(component.search.emit).toHaveBeenCalledWith(term);
  });

  it('should remove term from history', () => {
    const term = 'test';
    const event = new Event('click');
    spyOn(event, 'stopPropagation');

    component.onSearchChange(term);
    expect(component.searchHistory).toContain(term);

    component.removeFromHistory(term, event);

    expect(component.searchHistory).not.toContain(term);
    expect(event.stopPropagation).toHaveBeenCalled();
  });
});
